{
  "manifest_version": 2,
  "name": "AdbloK",
  "version": "1.0",
  "description": "Blocks ads and trackers based on a predefined list.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "storage",
    "activeTab"
  ],
  "background": {
      "scripts": ["background.js"]
    },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
